# Copy to .env and fill in as needed. All variables are prefixed QFAI_.

QFAI_ENVIRONMENT=development
QFAI_DEBUG=true

QFAI_LOG_LEVEL=INFO
QFAI_LOG_TO_FILE=true

QFAI_API_HOST=0.0.0.0
QFAI_API_PORT=8000

QFAI_STREAMLIT_PORT=8501

QFAI_DATABASE_NAME=quantforge.db

# MetaTrader 5 (used by later phases)
QFAI_MT5_LOGIN=
QFAI_MT5_PASSWORD=
QFAI_MT5_SERVER=
QFAI_MT5_TERMINAL_PATH=

# AI provider (used by later phases)
QFAI_AI_PROVIDER=
QFAI_AI_API_KEY=

# YouTube (used by later phases)
QFAI_YOUTUBE_API_KEY=
